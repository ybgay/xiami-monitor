<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.device.mapper.VirtualMasterMapper">
    
    <resultMap type="VirtualMaster" id="VirtualMasterResult">
        <result property="virtualId"    column="virtual_id"    />
        <result property="deviceId"    column="device_id"    />
        <result property="virtualName"    column="virtual_name"    />
        <result property="status"    column="status"    />
        <result property="ipAddress"    column="ip_address"    />
        <result property="createTime"    column="create_time"    />
        <result property="leader"    column="leader"    />
        <result property="osType"    column="os_type"    />
        <result property="username"    column="username"    />
        <result property="password"    column="password"    />
        <result property="remark"    column="remark"    />
        <result property="physicalId"    column="physical_id"    />
    </resultMap>

    <sql id="selectVirtualMasterVo">
        select virtual_id, device_id, virtual_name, status, ip_address, create_time, leader, os_type, username, password, remark, physical_id from virtual_master
    </sql>

    <select id="selectVirtualMasterList" parameterType="VirtualMaster" resultMap="VirtualMasterResult">
        <include refid="selectVirtualMasterVo"/>
        <where>  
            <if test="virtualName != null  and virtualName != ''"> and virtual_name like concat('%', #{virtualName}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="ipAddress != null  and ipAddress != ''"> and ip_address = #{ipAddress}</if>
            <if test="leader != null  and leader != ''"> and leader = #{leader}</if>
            <if test="osType != null  and osType != ''"> and os_type = #{osType}</if>
            <if test="username != null  and username != ''"> and username like concat('%', #{username}, '%')</if>
            <if test="physicalId != null "> and physical_id = #{physicalId}</if>
        </where>
    </select>
    
    <select id="selectVirtualMasterByVirtualId" parameterType="Long" resultMap="VirtualMasterResult">
        <include refid="selectVirtualMasterVo"/>
        where virtual_id = #{virtualId}
    </select>

    <insert id="insertVirtualMaster" parameterType="VirtualMaster" useGeneratedKeys="true" keyProperty="virtualId">
        insert into virtual_master
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deviceId != null">device_id,</if>
            <if test="virtualName != null and virtualName != ''">virtual_name,</if>
            <if test="status != null">status,</if>
            <if test="ipAddress != null and ipAddress != ''">ip_address,</if>
            <if test="createTime != null">create_time,</if>
            <if test="leader != null">leader,</if>
            <if test="osType != null and osType != ''">os_type,</if>
            <if test="username != null and username != ''">username,</if>
            <if test="password != null and password != ''">password,</if>
            <if test="remark != null">remark,</if>
            <if test="physicalId != null">physical_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deviceId != null">#{deviceId},</if>
            <if test="virtualName != null and virtualName != ''">#{virtualName},</if>
            <if test="status != null">#{status},</if>
            <if test="ipAddress != null and ipAddress != ''">#{ipAddress},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="leader != null">#{leader},</if>
            <if test="osType != null and osType != ''">#{osType},</if>
            <if test="username != null and username != ''">#{username},</if>
            <if test="password != null and password != ''">#{password},</if>
            <if test="remark != null">#{remark},</if>
            <if test="physicalId != null">#{physicalId},</if>
         </trim>
    </insert>

    <update id="updateVirtualMaster" parameterType="VirtualMaster">
        update virtual_master
        <trim prefix="SET" suffixOverrides=",">
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="virtualName != null and virtualName != ''">virtual_name = #{virtualName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="ipAddress != null and ipAddress != ''">ip_address = #{ipAddress},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="leader != null">leader = #{leader},</if>
            <if test="osType != null and osType != ''">os_type = #{osType},</if>
            <if test="username != null and username != ''">username = #{username},</if>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="physicalId != null">physical_id = #{physicalId},</if>
        </trim>
        where virtual_id = #{virtualId}
    </update>

    <delete id="deleteVirtualMasterByVirtualId" parameterType="Long">
        delete from virtual_master where virtual_id = #{virtualId}
    </delete>

    <delete id="deleteVirtualMasterByVirtualIds" parameterType="String">
        delete from virtual_master where virtual_id in 
        <foreach item="virtualId" collection="array" open="(" separator="," close=")">
            #{virtualId}
        </foreach>
    </delete>
</mapper>