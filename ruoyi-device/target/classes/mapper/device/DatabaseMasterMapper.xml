<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.device.mapper.DatabaseMasterMapper">
    
    <resultMap type="DatabaseMaster" id="DatabaseMasterResult">
        <result property="databaseId"    column="database_id"    />
        <result property="deviceId"    column="device_id"    />
        <result property="databaseName"    column="database_name"    />
        <result property="status"    column="status"    />
        <result property="ipAddress"    column="ip_address"    />
        <result property="port"    column="port"    />
        <result property="username"    column="username"    />
        <result property="password"    column="password"    />
        <result property="createTime"    column="create_time"    />
        <result property="leader"    column="leader"    />
        <result property="grafanaUrl"    column="grafana_url"    />
        <result property="version"    column="version"    />
    </resultMap>

    <sql id="selectDatabaseMasterVo">
        select database_id, device_id, database_name, status, ip_address, port, username, password, create_time, leader, grafana_url from database_master
    </sql>

    <select id="selectDatabaseMasterList" parameterType="DatabaseMaster" resultMap="DatabaseMasterResult">
        <include refid="selectDatabaseMasterVo"/>
        <where>  
            <if test="deviceId != null"> and device_id = #{deviceId}</if>
            <if test="databaseName != null  and databaseName != ''"> and database_name like concat('%', #{databaseName}, '%')</if>
            <if test="username != null  and username != ''"> and username like concat('%', #{username}, '%')</if>
            <if test="leader != null  and leader != ''"> and leader = #{leader}</if>
        </where>
    </select>
    
    <select id="selectDatabaseMasterByDatabaseId" parameterType="Long" resultMap="DatabaseMasterResult">
        <include refid="selectDatabaseMasterVo"/>
        where database_id = #{databaseId}
    </select>

    <insert id="insertDatabaseMaster" parameterType="DatabaseMaster" useGeneratedKeys="true" keyProperty="databaseId">
        insert into database_master
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deviceId != null">device_id,</if>
            <if test="databaseName != null and databaseName != ''">database_name,</if>
            <if test="status != null">status,</if>
            <if test="ipAddress != null and ipAddress != ''">ip_address,</if>
            <if test="port != null and port != ''">port,</if>
            <if test="username != null and username != ''">username,</if>
            <if test="password != null and password != ''">password,</if>
            <if test="createTime != null">create_time,</if>
            <if test="leader != null">leader,</if>
            <if test="grafanaUrl != null and grafanaUrl != ''">grafana_url,</if>
            <if test="version != null and version != ''">version,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deviceId != null">#{deviceId},</if>
            <if test="databaseName != null and databaseName != ''">#{databaseName},</if>
            <if test="status != null">#{status},</if>
            <if test="ipAddress != null and ipAddress != ''">#{ipAddress},</if>
            <if test="port != null and port != ''">#{port},</if>
            <if test="username != null and username != ''">#{username},</if>
            <if test="password != null and password != ''">#{password},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="leader != null">#{leader},</if>
            <if test="grafanaUrl != null and grafanaUrl != ''">#{grafanaUrl},</if>
            <if test="version != null and version != ''">#{version},</if>
         </trim>
    </insert>

    <update id="updateDatabaseMaster" parameterType="DatabaseMaster">
        update database_master
        <trim prefix="SET" suffixOverrides=",">
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="databaseName != null and databaseName != ''">database_name = #{databaseName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="ipAddress != null and ipAddress != ''">ip_address = #{ipAddress},</if>
            <if test="port != null and port != ''">port = #{port},</if>
            <if test="username != null and username != ''">username = #{username},</if>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="leader != null">leader = #{leader},</if>
            <if test="grafanaUrl != null and grafanaUrl != ''">grafana_url = #{grafanaUrl},</if>
            <if test="version != null and version != ''">version = #{version},</if>

        </trim>
        where database_id = #{databaseId}
    </update>

    <delete id="deleteDatabaseMasterByDatabaseId" parameterType="Long">
        delete from database_master where database_id = #{databaseId}
    </delete>

    <delete id="deleteDatabaseMasterByDatabaseIds" parameterType="String">
        delete from database_master where database_id in 
        <foreach item="databaseId" collection="array" open="(" separator="," close=")">
            #{databaseId}
        </foreach>
    </delete>
</mapper>