<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.device.mapper.PhysicalMasterMapper">
    
    <resultMap type="PhysicalMaster" id="PhysicalMasterResult">
        <result property="physicalId"    column="physical_id"    />
        <result property="physicalName"    column="physical_name"    />
        <result property="deviceId"    column="device_id"    />
        <result property="brand"    column="brand"    />
        <result property="model"    column="model"    />
        <result property="status"    column="status"    />
        <result property="macAddress"    column="mac_address"    />
        <result property="ipAddress"    column="ip_address"    />
        <result property="createTime"    column="create_time"    />
        <result property="leader"    column="leader"    />
        <result property="remark"    column="remark"    />
        <result property="username"    column="username"    />
        <result property="password"    column="password"    />
        <result property="isK8s" column="Is_k8s" />
     
    </resultMap>

    <sql id="selectPhysicalMasterVo">
        select physical_id, physical_name, device_id, brand, model, status, mac_address, ip_address, create_time, leader, remark,username,password,Is_k8s from physical_master
    </sql>

    <select id="selectPhysicalMasterList" parameterType="PhysicalMaster" resultMap="PhysicalMasterResult">
        <include refid="selectPhysicalMasterVo"/>
        <where>  
            <if test="physicalName != null  and physicalName != ''"> and physical_name like concat('%', #{physicalName}, '%')</if>
            <if test="deviceId != null "> and device_id = #{deviceId}</if>
            <if test="brand != null  and brand != ''"> and brand = #{brand}</if>
            <if test="model != null  and model != ''"> and model = #{model}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="macAddress != null  and macAddress != ''"> and mac_address = #{macAddress}</if>
            <if test="ipAddress != null  and ipAddress != ''"> and ip_address = #{ipAddress}</if>
            <if test="leader != null  and leader != ''"> and leader = #{leader}</if>
            <if test="username != null  and username != ''"> and username = #{username}</if>
            <if test="password != null  and password != ''"> and password = #{password}</if>
        </where>
    </select>
    
    <select id="selectPhysicalMasterByPhysicalId" parameterType="Long" resultMap="PhysicalMasterResult">
        <include refid="selectPhysicalMasterVo"/>
        where physical_id = #{physicalId}
    </select>

    <!-- 根据deviceId查询PhysicalMaster列表 -->
    <select id="selectPhysicalMasterByDeviceId" parameterType="java.lang.Integer" resultMap="PhysicalMasterResult">
        <include refid="selectPhysicalMasterVo"/>
        WHERE device_id = #{deviceId}
    </select>

    <insert id="insertPhysicalMaster" parameterType="PhysicalMaster" useGeneratedKeys="true" keyProperty="physicalId">
        insert into physical_master
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="physicalName != null and physicalName != ''">physical_name,</if>
            <if test="deviceId != null">device_id,</if>
            <if test="brand != null">brand,</if>
            <if test="model != null">model,</if>
            <if test="status != null">status,</if>
            <if test="macAddress != null">mac_address,</if>
            <if test="ipAddress != null">ip_address,</if>
            <if test="createTime != null">create_time,</if>
            <if test="leader != null">leader,</if>
            <if test="remark != null">remark,</if>
            <if test="username != null">username,</if>
            <if test="password != null">password,</if>
            <if test="isK8s != null">Is_k8s,</if>
        
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="physicalName != null and physicalName != ''">#{physicalName},</if>
            <if test="deviceId != null">#{deviceId},</if>
            <if test="brand != null">#{brand},</if>
            <if test="model != null">#{model},</if>
            <if test="status != null">#{status},</if>
            <if test="macAddress != null">#{macAddress},</if>
            <if test="ipAddress != null">#{ipAddress},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="leader != null">#{leader},</if>
            <if test="remark != null">#{remark},</if>
            <if test="username != null">#{username},</if>
            <if test="password != null">#{password},</if>
            <if test="isK8s != null">#{isK8s},</if>

         </trim>
    </insert>

    <update id="updatePhysicalMaster" parameterType="PhysicalMaster">
        update physical_master
        <trim prefix="SET" suffixOverrides=",">
            <if test="physicalName != null and physicalName != ''">physical_name = #{physicalName},</if>
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="brand != null">brand = #{brand},</if>
            <if test="model != null">model = #{model},</if>
            <if test="status != null">status = #{status},</if>
            <if test="macAddress != null">mac_address = #{macAddress},</if>
            <if test="ipAddress != null">ip_address = #{ipAddress},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="leader != null">leader = #{leader},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="isK8s != null">Is_k8s = #{isK8s},</if>
        </trim>
        where physical_id = #{physicalId}
    </update>

    <delete id="deletePhysicalMasterByPhysicalId" parameterType="Long">
        delete from physical_master where physical_id = #{physicalId}
    </delete>

    <delete id="deletePhysicalMasterByPhysicalIds" parameterType="String">
        delete from physical_master where physical_id in 
        <foreach item="physicalId" collection="array" open="(" separator="," close=")">
            #{physicalId}
        </foreach>
    </delete>
</mapper>