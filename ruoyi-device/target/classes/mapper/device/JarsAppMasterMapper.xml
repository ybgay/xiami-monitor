<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.device.mapper.JarsAppMasterMapper">

    <resultMap type="JarsAppMaster" id="JarsAppMasterResult">
        <result property="jarsId"       column="jars_id"       />
        <result property="deviceId"     column="device_id"     />
        <result property="appName"      column="app_name"      />
        <result property="appNameCn"    column="app_name_cn"   />
        <result property="category"     column="category"      />
        <result property="status"       column="status"        />
        <result property="ipAddress"    column="ip_address"    />
        <result property="port"         column="port"          />
        <result property="metricsPort"  column="metrics_port"  />
        <result property="metricsPath"  column="metrics_path"  />
        <result property="jvmArgs"      column="jvm_args"      />
        <result property="deployPath"   column="deploy_path"   />
        <result property="javaVersion"  column="java_version"  />
        <result property="leader"       column="leader"        />
        <result property="remark"       column="remark"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
    </resultMap>

    <sql id="selectJarsAppMasterVo">
        select jars_id, device_id, app_name, app_name_cn, category, status, ip_address, port,
               metrics_port, metrics_path, jvm_args, deploy_path, java_version,
               leader, remark, create_by, create_time, update_by, update_time
        from jars_app_master
    </sql>

    <select id="selectJarsAppMasterList" parameterType="JarsAppMaster" resultMap="JarsAppMasterResult">
        <include refid="selectJarsAppMasterVo"/>
        <where>
            <if test="deviceId != null"> and device_id = #{deviceId}</if>
            <if test="appName != null and appName != ''"> and app_name like concat('%', #{appName}, '%')</if>
            <if test="category != null and category != ''"> and category = #{category}</if>
            <if test="status != null"> and status = #{status}</if>
            <if test="ipAddress != null and ipAddress != ''"> and ip_address like concat('%', #{ipAddress}, '%')</if>
            <if test="leader != null and leader != ''"> and leader = #{leader}</if>
        </where>
        order by jars_id
    </select>

    <select id="selectJarsAppMasterByJarsId" parameterType="Long" resultMap="JarsAppMasterResult">
        <include refid="selectJarsAppMasterVo"/>
        where jars_id = #{jarsId}
    </select>

    <insert id="insertJarsAppMaster" parameterType="JarsAppMaster" useGeneratedKeys="true" keyProperty="jarsId">
        insert into jars_app_master
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deviceId != null">device_id,</if>
            <if test="appName != null and appName != ''">app_name,</if>
            <if test="appNameCn != null and appNameCn != ''">app_name_cn,</if>
            <if test="category != null and category != ''">category,</if>
            <if test="status != null">status,</if>
            <if test="ipAddress != null and ipAddress != ''">ip_address,</if>
            <if test="port != null and port != ''">port,</if>
            <if test="metricsPort != null and metricsPort != ''">metrics_port,</if>
            <if test="metricsPath != null and metricsPath != ''">metrics_path,</if>
            <if test="jvmArgs != null and jvmArgs != ''">jvm_args,</if>
            <if test="deployPath != null and deployPath != ''">deploy_path,</if>
            <if test="javaVersion != null and javaVersion != ''">java_version,</if>
            <if test="leader != null and leader != ''">leader,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deviceId != null">#{deviceId},</if>
            <if test="appName != null and appName != ''">#{appName},</if>
            <if test="appNameCn != null and appNameCn != ''">#{appNameCn},</if>
            <if test="category != null and category != ''">#{category},</if>
            <if test="status != null">#{status},</if>
            <if test="ipAddress != null and ipAddress != ''">#{ipAddress},</if>
            <if test="port != null and port != ''">#{port},</if>
            <if test="metricsPort != null and metricsPort != ''">#{metricsPort},</if>
            <if test="metricsPath != null and metricsPath != ''">#{metricsPath},</if>
            <if test="jvmArgs != null and jvmArgs != ''">#{jvmArgs},</if>
            <if test="deployPath != null and deployPath != ''">#{deployPath},</if>
            <if test="javaVersion != null and javaVersion != ''">#{javaVersion},</if>
            <if test="leader != null and leader != ''">#{leader},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateJarsAppMaster" parameterType="JarsAppMaster">
        update jars_app_master
        <trim prefix="SET" suffixOverrides=",">
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="appName != null and appName != ''">app_name = #{appName},</if>
            <if test="appNameCn != null">app_name_cn = #{appNameCn},</if>
            <if test="category != null and category != ''">category = #{category},</if>
            <if test="status != null">status = #{status},</if>
            <if test="ipAddress != null and ipAddress != ''">ip_address = #{ipAddress},</if>
            <if test="port != null and port != ''">port = #{port},</if>
            <if test="metricsPort != null">metrics_port = #{metricsPort},</if>
            <if test="metricsPath != null">metrics_path = #{metricsPath},</if>
            <if test="jvmArgs != null">jvm_args = #{jvmArgs},</if>
            <if test="deployPath != null">deploy_path = #{deployPath},</if>
            <if test="javaVersion != null">java_version = #{javaVersion},</if>
            <if test="leader != null">leader = #{leader},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where jars_id = #{jarsId}
    </update>

    <delete id="deleteJarsAppMasterByJarsId" parameterType="Long">
        delete from jars_app_master where jars_id = #{jarsId}
    </delete>

    <delete id="deleteJarsAppMasterByJarsIds" parameterType="String">
        delete from jars_app_master where jars_id in
        <foreach item="jarsId" collection="array" open="(" separator="," close=")">
            #{jarsId}
        </foreach>
    </delete>

</mapper>
