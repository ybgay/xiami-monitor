<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.device.mapper.PhysicalMachineBaseMapper">
    
    <resultMap type="PhysicalMachineBase" id="PhysicalMachineBaseResult">
        <result property="machineId"    column="machine_id"    />
        <result property="machineName"    column="machine_name"    />
        <result property="machineType"    column="machine_type"    />
        <result property="brand"    column="brand"    />
        <result property="model"    column="model"    />
        <result property="status"    column="status"    />
        <result property="roomId"    column="room_id"    />
        <result property="purchaseTime"    column="purchase_time"    />
        <result property="warrantyExpire"    column="warranty_expire"    />
        <result property="adminUser"    column="admin_user"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectPhysicalMachineBaseVo">
        select machine_id, machine_name, machine_type, brand, model, status, room_id, purchase_time, warranty_expire, admin_user, create_time, update_time from physical_machine_base
    </sql>

    <select id="selectPhysicalMachineBaseList" parameterType="PhysicalMachineBase" resultMap="PhysicalMachineBaseResult">
        <include refid="selectPhysicalMachineBaseVo"/>
        <where>  
            <if test="machineName != null  and machineName != ''"> and machine_name like concat('%', #{machineName}, '%')</if>
            <if test="machineType != null  and machineType != ''"> and machine_type = #{machineType}</if>
            <if test="brand != null  and brand != ''"> and brand = #{brand}</if>
            <if test="model != null  and model != ''"> and model = #{model}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="roomId != null  and roomId != ''"> and room_id = #{roomId}</if>
            <if test="purchaseTime != null "> and purchase_time = #{purchaseTime}</if>
            <if test="warrantyExpire != null "> and warranty_expire = #{warrantyExpire}</if>
            <if test="adminUser != null  and adminUser != ''"> and admin_user = #{adminUser}</if>
        </where>
    </select>
    
    <select id="selectPhysicalMachineBaseByMachineId" parameterType="String" resultMap="PhysicalMachineBaseResult">
        <include refid="selectPhysicalMachineBaseVo"/>
        where machine_id = #{machineId}
    </select>

    <insert id="insertPhysicalMachineBase" parameterType="PhysicalMachineBase">
        insert into physical_machine_base
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="machineId != null">machine_id,</if>
            <if test="machineName != null and machineName != ''">machine_name,</if>
            <if test="machineType != null and machineType != ''">machine_type,</if>
            <if test="brand != null and brand != ''">brand,</if>
            <if test="model != null and model != ''">model,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="roomId != null and roomId != ''">room_id,</if>
            <if test="purchaseTime != null">purchase_time,</if>
            <if test="warrantyExpire != null">warranty_expire,</if>
            <if test="adminUser != null and adminUser != ''">admin_user,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="machineId != null">#{machineId},</if>
            <if test="machineName != null and machineName != ''">#{machineName},</if>
            <if test="machineType != null and machineType != ''">#{machineType},</if>
            <if test="brand != null and brand != ''">#{brand},</if>
            <if test="model != null and model != ''">#{model},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="roomId != null and roomId != ''">#{roomId},</if>
            <if test="purchaseTime != null">#{purchaseTime},</if>
            <if test="warrantyExpire != null">#{warrantyExpire},</if>
            <if test="adminUser != null and adminUser != ''">#{adminUser},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updatePhysicalMachineBase" parameterType="PhysicalMachineBase">
        update physical_machine_base
        <trim prefix="SET" suffixOverrides=",">
            <if test="machineName != null and machineName != ''">machine_name = #{machineName},</if>
            <if test="machineType != null and machineType != ''">machine_type = #{machineType},</if>
            <if test="brand != null and brand != ''">brand = #{brand},</if>
            <if test="model != null and model != ''">model = #{model},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="roomId != null and roomId != ''">room_id = #{roomId},</if>
            <if test="purchaseTime != null">purchase_time = #{purchaseTime},</if>
            <if test="warrantyExpire != null">warranty_expire = #{warrantyExpire},</if>
            <if test="adminUser != null and adminUser != ''">admin_user = #{adminUser},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where machine_id = #{machineId}
    </update>

    <delete id="deletePhysicalMachineBaseByMachineId" parameterType="String">
        delete from physical_machine_base where machine_id = #{machineId}
    </delete>

    <delete id="deletePhysicalMachineBaseByMachineIds" parameterType="String">
        delete from physical_machine_base where machine_id in 
        <foreach item="machineId" collection="array" open="(" separator="," close=")">
            #{machineId}
        </foreach>
    </delete>
</mapper>