{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "xiami-monitor"
  },
  "spec": {
    "replicas": 1,
    "selector": {
      "matchLabels": {
        "app": "xiami-monitor"
      }
    },
    "template": {
      "metadata": {
        "labels": {
          "app": "xiami-monitor"
        }
      },
      "spec": {
        "containers": [
          {
            "name": "xiami-monitor",
            "image": "xiami-monitor:1.0",
            "imagePullPolicy": "IfNotPresent",
            "ports": [
              {
                "containerPort": 30812
              }
            ],
            "resources": {
              "requests": {
                "memory": "256Mi",
                "cpu": "250m"
              },
              "limits": {
                "memory": "512Mi",
                "cpu": "500m"
              }
            }
          }
        ]
      }
    }
  }
}