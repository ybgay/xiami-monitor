<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.JarsPanelConfigMapper">

    <resultMap type="com.ruoyi.system.domain.JarsPanelConfig" id="JarsPanelConfigResult">
        <result property="id"               column="id"                />
        <result property="device"            column="device"             />
        <result property="category"          column="category"           />
        <result property="appName"           column="app_name"           />
        <result property="panelKey"          column="panel_key"          />
        <result property="panelName"         column="panel_name"         />
        <result property="panelGroup"        column="panel_group"        />
        <result property="isCustom"          column="is_custom"          />
        <result property="grafanaPanelId"    column="grafana_panel_id"   />
        <result property="promql"            column="promql"             />
        <result property="chartType"         column="chart_type"         />
        <result property="unit"              column="unit"               />
        <result property="timeRange"         column="time_range"         />
        <result property="refreshInterval"   column="refresh_interval"   />
        <result property="scope"             column="scope"              />
        <result property="sortOrder"         column="sort_order"         />
        <result property="groupSortOrder"    column="group_sort_order"   />
        <result property="panelSpan"         column="panel_span"         />
        <result property="description"       column="description"        />
        <result property="delFlag"           column="del_flag"           />
        <result property="createBy"          column="create_by"          />
        <result property="createTime"        column="create_time"        />
        <result property="updateBy"          column="update_by"          />
        <result property="updateTime"        column="update_time"        />
        <result property="remark"            column="remark"             />
    </resultMap>

    <sql id="selectJarsPanelConfigVo">
        select id, device, category, app_name, panel_key, panel_name, panel_group, is_custom,
               grafana_panel_id, promql, chart_type, unit, time_range,
               refresh_interval, scope, sort_order, group_sort_order, panel_span,
               description, create_by, create_time, update_by, update_time, remark
        from jars_monitor_panel_config
        where del_flag = '0'
    </sql>

    <select id="selectPanelConfigList" parameterType="com.ruoyi.system.domain.JarsPanelConfig" resultMap="JarsPanelConfigResult">
        <include refid="selectJarsPanelConfigVo"/>
        <if test="device != null and device != ''">
            AND (device = #{device} OR device = 'All')
        </if>
        <if test="category != null and category != ''">
            AND (category = #{category} OR category = 'All')
        </if>
        <if test="appName != null and appName != ''">
            AND (app_name = #{appName} OR app_name = 'All')
        </if>
        order by group_sort_order asc, sort_order asc, id asc
    </select>

    <select id="selectPanelConfigById" parameterType="Long" resultMap="JarsPanelConfigResult">
        <include refid="selectJarsPanelConfigVo"/>
        AND id = #{id}
    </select>

    <select id="selectPanelConfigByKey" parameterType="com.ruoyi.system.domain.JarsPanelConfig" resultMap="JarsPanelConfigResult">
        <include refid="selectJarsPanelConfigVo"/>
        AND device    = #{device}
        AND category  = #{category}
        AND app_name  = #{appName}
        AND panel_key = #{panelKey}
        LIMIT 1
    </select>

    <insert id="insertPanelConfig" parameterType="com.ruoyi.system.domain.JarsPanelConfig" useGeneratedKeys="true" keyProperty="id">
        insert into jars_monitor_panel_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="device != null and device != ''">device,</if>
            <if test="category != null and category != ''">category,</if>
            <if test="appName != null and appName != ''">app_name,</if>
            <if test="panelKey != null and panelKey != ''">panel_key,</if>
            <if test="panelName != null and panelName != ''">panel_name,</if>
            <if test="panelGroup != null and panelGroup != ''">panel_group,</if>
            <if test="isCustom != null">is_custom,</if>
            <if test="grafanaPanelId != null">grafana_panel_id,</if>
            <if test="promql != null">promql,</if>
            <if test="chartType != null and chartType != ''">chart_type,</if>
            <if test="unit != null and unit != ''">unit,</if>
            <if test="timeRange != null and timeRange != ''">time_range,</if>
            <if test="refreshInterval != null">refresh_interval,</if>
            <if test="scope != null and scope != ''">scope,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="groupSortOrder != null">group_sort_order,</if>
            <if test="panelSpan != null">panel_span,</if>
            <if test="description != null">description,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            del_flag,
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="device != null and device != ''">#{device},</if>
            <if test="category != null and category != ''">#{category},</if>
            <if test="appName != null and appName != ''">#{appName},</if>
            <if test="panelKey != null and panelKey != ''">#{panelKey},</if>
            <if test="panelName != null and panelName != ''">#{panelName},</if>
            <if test="panelGroup != null and panelGroup != ''">#{panelGroup},</if>
            <if test="isCustom != null">#{isCustom},</if>
            <if test="grafanaPanelId != null">#{grafanaPanelId},</if>
            <if test="promql != null">#{promql},</if>
            <if test="chartType != null and chartType != ''">#{chartType},</if>
            <if test="unit != null and unit != ''">#{unit},</if>
            <if test="timeRange != null and timeRange != ''">#{timeRange},</if>
            <if test="refreshInterval != null">#{refreshInterval},</if>
            <if test="scope != null and scope != ''">#{scope},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="groupSortOrder != null">#{groupSortOrder},</if>
            <if test="panelSpan != null">#{panelSpan},</if>
            <if test="description != null">#{description},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            '0',
            sysdate()
        </trim>
    </insert>

    <update id="updatePanelConfig" parameterType="com.ruoyi.system.domain.JarsPanelConfig">
        update jars_monitor_panel_config
        <set>
            <if test="panelName != null and panelName != ''">panel_name = #{panelName},</if>
            <if test="panelGroup != null and panelGroup != ''">panel_group = #{panelGroup},</if>
            <if test="grafanaPanelId != null">grafana_panel_id = #{grafanaPanelId},</if>
            <if test="promql != null">promql = #{promql},</if>
            <if test="chartType != null and chartType != ''">chart_type = #{chartType},</if>
            <if test="unit != null and unit != ''">unit = #{unit},</if>
            <if test="timeRange != null and timeRange != ''">time_range = #{timeRange},</if>
            <if test="refreshInterval != null">refresh_interval = #{refreshInterval},</if>
            <if test="scope != null and scope != ''">scope = #{scope},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="groupSortOrder != null">group_sort_order = #{groupSortOrder},</if>
            <if test="panelSpan != null">panel_span = #{panelSpan},</if>
            <if test="description != null">description = #{description},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <update id="deletePanelConfigById" parameterType="Long">
        update jars_monitor_panel_config set del_flag = '2', update_time = sysdate()
        where id = #{id}
    </update>

    <update id="deletePanelConfigByIds" parameterType="Long">
        update jars_monitor_panel_config set del_flag = '2', update_time = sysdate()
        where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 批量更新排序和宽度（CASE WHEN 单语句，兼容不开 allowMultiQueries 的环境） -->
    <update id="batchUpdateSort">
        UPDATE jars_monitor_panel_config
        SET
            sort_order = CASE id
                <foreach collection="list" item="item">
                    WHEN #{item.id} THEN #{item.sortOrder}
                </foreach>
                ELSE sort_order
            END,
            group_sort_order = CASE id
                <foreach collection="list" item="item">
                    WHEN #{item.id} THEN #{item.groupSortOrder}
                </foreach>
                ELSE group_sort_order
            END,
            panel_span = CASE id
                <foreach collection="list" item="item">
                    WHEN #{item.id} THEN #{item.panelSpan}
                </foreach>
                ELSE panel_span
            END,
            update_time = sysdate()
        WHERE id IN
        <foreach collection="list" item="item" open="(" separator="," close=")">
            #{item.id}
        </foreach>
    </update>

</mapper>
